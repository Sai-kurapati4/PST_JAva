class Solution {
    public int lengthOfLongestSubstring(String s) {
         HashSet<Character> ne=new HashSet<>();
         int max=0;
         int j=0;
         for(int i=0;i<s.length();i++){
            while(ne.contains(s.charAt(i))){
                ne.remove(s.charAt(j));
                j++;
            }
            ne.add(s.charAt(i));
            max=Math.max(max,i-j+1);
         }
         return max;
    }
}
