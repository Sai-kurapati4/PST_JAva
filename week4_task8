class Solution {
    public int[][] transpose(int[][] matrix) {
        int r=matrix.length;
        int c=matrix[0].length;
                        int[][] ne=new int[c][r];
                for(int l=0;l<r;l++){
                    for(int p=0;p<c;p++){
                    ne[p][l]=matrix[l][p];
                    }
                }

        return ne;
    }
}
