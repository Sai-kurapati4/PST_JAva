class Solution {
    public boolean halvesAreAlike(String s) {
        s=s.toLowerCase();
        int count1=0;
        int count2=0;
        int n=s.length();
        int mid=n/2;
for(int i=0;i<n/2;i++){
char ch=s.charAt(i);
if(ch=='a'||ch=='e'||ch=='i'||ch=='o'||ch=='u'){
    count1+=1;
}
ch=s.charAt(mid+i);
if(ch=='a'||ch=='e'||ch=='i'||ch=='o'||ch=='u'){
    count2+=1;
}}
if(count1==count2){
    return true;
}
else{
    return false;
}
              }
}
