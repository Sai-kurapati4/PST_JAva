import java.util.Arrays;

class Solution {
    public void moveZeroes(int[] nums) {
        int n = nums.length;
        int i = 0;
        for (i = 0; i < n; i++) {
            if (nums[i] == 0) {
                for (int k = i; k < n - 1; k++) {
                    nums[k] = nums[k + 1];
                }
                nums[n - 1] = 0;
                i--;
                n--;
            }
        }

        System.out.println(Arrays.toString(nums));
    }
}
